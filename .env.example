# Core model and retrieval configuration
OPENAI_API_KEY=your_openai_api_key
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=your_pinecone_index_name

# Optional AWS deployment configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=your_aws_region
S3_GRAPH_BUCKET=your_runtime_assets_bucket

# Optional runtime overrides
ADI_RUNTIME_BUNDLE_BUCKET=your_runtime_assets_bucket
ADI_RUNTIME_BUNDLE_PREFIX=runtime-bundle
ADI_RUNTIME_STATE_BUCKET=your_runtime_assets_bucket
ADI_RUNTIME_STATE_PREFIX=runtime-state
