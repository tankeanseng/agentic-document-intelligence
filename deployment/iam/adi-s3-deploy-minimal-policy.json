{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowBucketLevelListingForDeploymentPrefixes",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": "arn:aws:s3:::rag-universal-knowledge",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "runtime-bundle/*",
            "frontend-site/*",
            "adi-frontend/*"
          ]
        }
      }
    },
    {
      "Sid": "AllowObjectLevelDeploymentAccessForScopedPrefixes",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:AbortMultipartUpload",
        "s3:ListBucketMultipartUploads",
        "s3:ListMultipartUploadParts"
      ],
      "Resource": [
        "arn:aws:s3:::rag-universal-knowledge/runtime-bundle/*",
        "arn:aws:s3:::rag-universal-knowledge/frontend-site/*",
        "arn:aws:s3:::rag-universal-knowledge/adi-frontend/*"
      ]
    }
  ]
}
